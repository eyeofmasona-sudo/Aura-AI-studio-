# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Safe Google/Gemini API config integration
GOOGLE_AI_API_KEY=""
GOOGLE_AI_TEXT_CHEAP_MODEL="gemini-3.5-flash"
GOOGLE_AI_TEXT_BALANCED_MODEL="gemini-3.5-flash"
GOOGLE_AI_TEXT_STRONG_MODEL="gemini-3.1-pro-preview"
GOOGLE_AI_IMAGE_MODEL="gemini-2.5-flash-image"
GOOGLE_AI_VIDEO_MODEL="veo-3.1-lite-generate-preview"
GOOGLE_AI_AUDIO_MODEL="gemini-3.1-flash-live-preview"
GOOGLE_AI_TTS_MODEL="gemini-3.1-flash-tts-preview"
GOOGLE_AI_DEFAULT_MODEL="gemini-3.5-flash"

# Google Cloud Text-to-Speech API
# Required for voice synthesis in Voice module
GOOGLE_CLOUD_TTS_API_KEY=""
